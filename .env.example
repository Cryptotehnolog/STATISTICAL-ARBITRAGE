# Пример локальной конфигурации.
# Скопируйте файл в .env и заполните реальные значения.
# Никогда не коммитьте .env в Git.

# ============================================================================
# Infisical configuration (обязательно)
# ============================================================================
# Локальный self-host instance поднимается через:
#   .\scripts\init_infisical_env.ps1
#   .\scripts\start_infisical.ps1
INFISICAL_API_URL=http://localhost:8080
INFISICAL_CLIENT_ID=your_client_id_here
INFISICAL_CLIENT_SECRET=your_client_secret_here
INFISICAL_PROJECT_ID=your_project_id_here
INFISICAL_PROJECT_SLUG=
INFISICAL_ORGANIZATION_SLUG=
INFISICAL_ENVIRONMENT=dev
INFISICAL_SECRET_PATH=/
INFISICAL_TIMEOUT_SECONDS=20

# ============================================================================
# Database Configuration
# ============================================================================
# SQLite (default for local development)
DATABASE_URL=sqlite:///./data/registry.db

# PostgreSQL (optional, for production-like testing)
# DATABASE_URL=postgresql://user:password@localhost:5432/stat_arb

# ============================================================================
# ApeRAG Configuration
# ============================================================================
APERAG_API_BASE_URL=http://127.0.0.1:18000
APERAG_API_KEY=stored_in_infisical
APERAG_COLLECTION_TITLE=stat-arb-project-knowledge
APERAG_AGENT_COLLECTION_TITLE=stat-arb-agent-memory
APERAG_TIMEOUT_SECONDS=60
APERAG_SEARCH_TOP_K=5
APERAG_SEARCH_SIMILARITY=0.1
APERAG_EMBEDDING_PROVIDER=stat-arb-local-embeddings
APERAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
APERAG_COMPLETION_BACKEND=omniroute
APERAG_COMPLETION_PROVIDER=stat-arb-omniroute
APERAG_COMPLETION_MODEL=my-ai

# Экспериментальный ApeRAG graph fallback через FreeDeepseekAPI.
# FreeDeepseekAPI должен работать в отдельном Docker container и использовать локальные
# DeepSeek Web session files из data/free_deepseek/. Не коммитить deepseek-auth.json
# или Chrome profiles.
FREE_DEEPSEEK_BASE_URL=http://127.0.0.1:9655/v1
FREE_DEEPSEEK_MODEL=deepseek-chat

# Экспериментальный ApeRAG graph fallback через FreeQwenApi.
# FreeQwenApi должен работать в отдельном Docker container и использовать локальную
# Qwen Chat session из data/free_qwen/session/. Не коммитить tokens.json,
# session/accounts/** или Authorization.txt.
FREE_QWEN_BASE_URL=http://127.0.0.1:3264/api
FREE_QWEN_MODEL=qwen3.7-plus

# ============================================================================
# Data source API keys (хранятся в Infisical)
# ============================================================================
# Эти значения загружаются из Infisical, а не из .env.
# Здесь они перечислены только как документация.

# Smoke-test secret
# - STAT_ARB_INFISICAL_SMOKE_SECRET

# Cryptocurrency exchanges (CCXT)
# - BINANCE_API_KEY
# - BINANCE_API_SECRET
# - COINBASE_API_KEY
# - COINBASE_API_SECRET
# - KRAKEN_API_KEY
# - KRAKEN_API_SECRET

# US Equities
# - ALPACA_API_KEY
# - ALPACA_API_SECRET
# - ALPACA_BASE_URL (paper: https://paper-api.alpaca.markets, live: https://api.alpaca.markets)

# Alternative data sources
# - POLYGON_API_KEY

# ============================================================================
# LLM Configuration (Optional)
# ============================================================================
# LLM gateway (OpenAI-compatible)
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=http://localhost:20128/v1
LLM_MODEL=my-ai
LLM_API_KEY=stored_in_infisical

# Token budgets
LLM_TOKEN_BUDGET_PER_AGENT=10000
LLM_TOKEN_BUDGET_PER_RUN=50000
LLM_MAX_RETRIES=3

# ============================================================================
# System Configuration
# ============================================================================
# Environment: research, demo, or live
SYSTEM_ENVIRONMENT=research

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json  # json or console

# Data paths
DATA_DIR=./data
PARQUET_DIR=./data/parquet
REPORTS_DIR=./data/reports

# ============================================================================
# Research Configuration
# ============================================================================
# Default timeframes
DEFAULT_TIMEFRAME=15m
SECONDARY_TIMEFRAME=5m

# Data quality thresholds
MAX_MISSING_BARS_PCT=5.0
MAX_OUTLIERS_PCT=1.0
MIN_DATA_POINTS=1000
MIN_ALIGNMENT_PCT=95.0

# Statistical testing thresholds
COINTEGRATION_P_VALUE_THRESHOLD=0.05
ADF_P_VALUE_THRESHOLD=0.05
MIN_HEDGE_RATIO_R_SQUARED=0.3
MIN_HALF_LIFE_DAYS=1.0
MAX_HALF_LIFE_DAYS=30.0

# Backtesting configuration
TRAIN_WINDOW_DAYS=60
TEST_WINDOW_DAYS=30
MIN_WALK_FORWARD_WINDOWS=3

# Cost assumptions (v1 defaults)
COMMISSION_PCT=0.1
SPREAD_PCT=0.05
SLIPPAGE_PCT=0.02
FUNDING_RATE_DAILY_PCT=0.01
BORROW_COST_ANNUAL_PCT=0.5

# ============================================================================
# Dashboard Configuration
# ============================================================================
DASHBOARD_HOST=localhost
DASHBOARD_PORT=8501

# ============================================================================
# Monitoring and Alerts (Optional)
# ============================================================================
# Telegram notifications
# TELEGRAM_BOT_TOKEN=stored_in_infisical
# TELEGRAM_CHAT_ID=stored_in_infisical

# Webhook notifications
# WEBHOOK_URL=stored_in_infisical

# ============================================================================
# Development Settings
# ============================================================================
# Enable debug mode
DEBUG=false

# Enable profiling
ENABLE_PROFILING=false

# Random seed for reproducibility
RANDOM_SEED=42
