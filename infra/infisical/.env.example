# Локальная self-host конфигурация Infisical.
# Скопируйте через scripts/init_infisical_env.ps1; реальные значения не коммитить.

INFISICAL_IMAGE_TAG=latest
INFISICAL_HOST_PORT=8080

ENCRYPTION_KEY=replace-with-generated-hex-key
AUTH_SECRET=replace-with-generated-base64-secret

INFISICAL_POSTGRES_USER=infisical
INFISICAL_POSTGRES_PASSWORD=replace-with-generated-hex-password
INFISICAL_POSTGRES_DB=infisical

SMTP_HOST=
SMTP_PORT=
SMTP_FROM_ADDRESS=
SMTP_FROM_NAME=
SMTP_USERNAME=
SMTP_PASSWORD=

OTEL_TELEMETRY_COLLECTION_ENABLED=false
OTEL_EXPORT_TYPE=prometheus
